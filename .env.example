# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://wecare4you:wecare4you@localhost:5433/wecare4you_db"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-at-least-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-at-least-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Termii (SMS / OTP) ───────────────────────────────────────────────────────
TERMII_API_KEY="your-termii-api-key"
TERMII_SENDER_ID="WeCare4You"
TERMII_BASE_URL="https://api.ng.termii.com/api"

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_live_xxxxx"
PAYSTACK_PUBLIC_KEY="pk_live_xxxxx"
PAYSTACK_WEBHOOK_SECRET="your-webhook-secret"

# ─── Daily.co ─────────────────────────────────────────────────────────────────
DAILY_API_KEY="your-daily-api-key"
DAILY_DOMAIN="your-domain.daily.co"

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
API_HOST="0.0.0.0"
FRONTEND_URL="http://localhost:3000"
MOBILE_DEEP_LINK="wecare4you://"

# ─── Platform commission rates ───────────────────────────────────────────────
THERAPIST_COMMISSION_RATE=0.20
BUDDY_COMMISSION_RATE=0.25
MINIMUM_PAYOUT_KOBO=500000
